<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- LINKS -->
    <link name="arm_base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${arm_base_length} ${arm_base_length} ${arm_base_height}" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="${arm_base_length} ${arm_base_length} ${arm_base_height}" />
            </geometry>
        </collision>
        <xacro:box_inertia m="0.5" x="${arm_base_length}" y="${arm_base_length}" z="${arm_base_height}" />
    </link>

    <link name="forearm_link">
        <visual>
            <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder radius="${arm_link_radius}" length="${arm_link_length}" />
            </geometry>
            <material name="yellow" />
        </visual>
        <collision>
            <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder radius="${arm_link_radius}" length="${arm_link_length}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.3" r="${arm_link_radius}" h="${arm_link_length}" />
    </link>

    <link name="hand_link">
        <visual>
            <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder radius="${arm_link_radius}" length="${arm_link_length}" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin xyz="0 0 ${arm_link_length/2}" rpy="0 0 0" />
            <geometry>
                <cylinder radius="${arm_link_radius}" length="${arm_link_length}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.3" r="${arm_link_radius}" h="${arm_link_length}" />
    </link>

    <!-- JOINTs -->
    <joint name="base_to_arm_base_joint" type="fixed">
        <parent link="base_link" />
        <child link="arm_base_link" />
        <origin xyz="${chassis_length/5} 0 ${chassis_height+arm_base_height/2}" rpy="0 0 0" />
    </joint>

    <joint name="arm_base_to_forearm_joint" type="revolute">
        <parent link="arm_base_link" />
        <child link="forearm_link" />
        <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="0" upper="${pi/2}" effort="100" velocity="100" />
        <!-- <dynamics friction="0.3" damping="0.3" /> -->
    </joint>

    <joint name="forearm_to_hand_joint" type="revolute">
        <parent link="forearm_link" />
        <child link="hand_link" />
        <origin xyz="0 0 ${arm_link_length}" rpy="0 0 0" />
        <axis xyz="0 1 0" />
        <limit lower="0" upper="${pi/2}" effort="100" velocity="100" />
        <!-- <dynamics friction="0.3" damping="0.3" /> -->
    </joint>
</robot>